{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@loom/config": ["packages/config/src/index.ts"],
      "@loom/runtime-podman": ["packages/runtime-podman/src/index.ts"],
      "@loom/core": ["packages/core/src/index.ts"],
      "@loom/tasks": ["packages/tasks/src/index.ts"],
      "@loom/network": ["packages/network/src/index.ts"],
      "@loom/https": ["packages/https/src/index.ts"]
    },
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  }
}
