---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Loom Astro Template">
  <main>
    <h1><span class="gradient">Loom</span> + Astro</h1>
    <p>Your Astro app is running on <code>https://astro.loom.local</code></p>
    <div class="card">
      <p>Start building your site by editing <code>src/pages/index.astro</code></p>
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 640px;
    margin: 4rem auto;
    padding: 2rem;
    text-align: center;
    font-family: system-ui, sans-serif;
  }
  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .gradient {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .card {
    margin-top: 2rem;
    padding: 1.25rem;
    background: #1e1e2e;
    border-radius: 8px;
    border: 1px solid #313244;
  }
  code {
    background: #313244;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>
