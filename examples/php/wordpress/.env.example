# Example alternatives:
# WORDPRESS_IMAGE=docker.io/library/wordpress:6-php8.3-apache
# WORDPRESS_IMAGE=docker.io/library/wordpress:6-php8.4-apache
# MEMCACHED_IMAGE=docker.io/library/memcached:1.6-alpine
WORDPRESS_IMAGE=docker.io/library/wordpress:6-php8.3-apache
MEMCACHED_IMAGE=docker.io/library/memcached:1.6-alpine

# Database — set by loomWordPressEnv() in wp-config.php
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_TABLE_PREFIX=wp_

# Security
# WORDPRESS_AUTH_KEY=your-unique-phrase
# WORDPRESS_SECURE_AUTH_KEY=your-unique-phrase
# WORDPRESS_LOGGED_IN_KEY=your-unique-phrase
# WORDPRESS_NONCE_KEY=your-unique-phrase
# WORDPRESS_AUTH_SALT=your-unique-phrase
# WORDPRESS_SECURE_AUTH_SALT=your-unique-phrase
# WORDPRESS_LOGGED_IN_SALT=your-unique-phrase
# WORDPRESS_NONCE_SALT=your-unique-phrase
# WORDPRESS_DEBUG=1

HOST_UID=1000
HOST_GID=1000
