{
  "name": "@loom/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "loom": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/**/*.test.js || true",
    "dev": "tsx src/index.ts",
    "lint": "echo 'No lint configured for @loom/cli'"
  },
  "dependencies": {
    "@loom/config": "workspace:*",
    "@loom/core": "workspace:*",
    "@loom/tasks": "workspace:*",
    "cac": "^6.7.14"
  }
}
