{
  "name": "@loom/config",
  "version": "0.1.0",
  "description": "Configuration loading and schema validation for Loom projects.",
  "keywords": [
    "loom",
    "podman",
    "config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Loom-development/Loom.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/Loom-development/Loom/issues"
  },
  "homepage": "https://github.com/Loom-development/Loom#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -b tsconfig.json",
    "typecheck": "pnpm exec tsc -b tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "lint": "echo 'No lint rules configured'"
  },
  "dependencies": {
    "yaml": "^2.7.1",
    "zod": "^3.24.2"
  }
}
