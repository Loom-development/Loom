{
  "name": "@loom/https",
  "version": "0.1.1",
  "description": "Local HTTPS certificate utilities for Loom routes.",
  "keywords": [
    "loom",
    "https",
    "certificates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Loom-development/Loom.git",
    "directory": "packages/https"
  },
  "bugs": {
    "url": "https://github.com/Loom-development/Loom/issues"
  },
  "homepage": "https://github.com/Loom-development/Loom#readme",
  "license": "Elastic-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -b tsconfig.json",
    "typecheck": "pnpm exec tsc -b tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "lint": "echo 'No lint rules configured'"
  }
}
