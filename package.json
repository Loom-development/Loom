{
  "name": "loom-dev",
  "version": "0.1.0",
  "private": true,
  "description": "Loom - Podman-based local development platform",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm exec tsc -b tsconfig.json",
    "typecheck": "pnpm exec tsc -b tsconfig.json",
    "dev": "pnpm --filter @loom/cli dev",
    "smoke:stacks": "./scripts/smoke-stacks.sh",
    "test": "pnpm -r test",
    "test:coverage": "c8 --all --include='packages/*/dist/**/*.js' --include='apps/*/dist/**/*.js' --exclude='**/*.test.js' --check-coverage --lines 35 --functions 35 --branches 25 pnpm -r test",
    "test:coverage:report": "c8 --all --include='packages/*/dist/**/*.js' --include='apps/*/dist/**/*.js' --exclude='**/*.test.js' --check-coverage --lines 35 --functions 35 --branches 25 --reporter=text-summary --reporter=lcov --reporter=json-summary pnpm -r test",
    "lint": "pnpm exec eslint \"apps/*/src/**/*.ts\" \"packages/*/src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@types/node": "^22.13.10",
    "c8": "^10.1.3",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
