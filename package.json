{
  "name": "@loomdev/cli",
  "version": "0.3.4",
  "private": true,
  "description": "Loom - Podman-based local development platform",
  "license": "Elastic-2.0",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm exec tsc -b tsconfig.json && node scripts/build-cli-package-assets.mjs",
    "typecheck": "pnpm exec tsc -b tsconfig.json",
    "dev": "pnpm --filter @loomdev/cli dev",
    "smoke:examples": "./scripts/smoke-examples.sh",
    "smoke:release": "./scripts/release-smoke.sh",
    "test": "pnpm -r test",
    "test:coverage": "c8 --all --include='packages/*/dist/**/*.js' --include='apps/*/dist/**/*.js' --exclude='**/*.test.js' --check-coverage --lines 35 --functions 35 --branches 25 pnpm -r test",
    "test:coverage:report": "c8 --all --include='packages/*/dist/**/*.js' --include='apps/*/dist/**/*.js' --exclude='**/*.test.js' --check-coverage --lines 35 --functions 35 --branches 25 --reporter=text-summary --reporter=lcov --reporter=json-summary pnpm -r test",
    "lint": "pnpm exec eslint \"apps/*/src/**/*.ts\" \"packages/*/src/**/*.ts\"",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "verify:coverage": "pnpm lint && pnpm typecheck && pnpm test:coverage:report"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "c8": "^10.1.3",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.5",
    "globals": "^15.15.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
